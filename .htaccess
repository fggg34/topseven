<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Handle root - send to public/index.php
    RewriteRule ^$ public/index.php [L]

    # 3. Send all other requests to public folder (skip if already /public/...)
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# 4. Security: Disable directory listings
Options -Indexes
